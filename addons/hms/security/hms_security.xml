<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- HMS Application Category -->
    <record id="module_category_hms" model="ir.module.category">
        <field name="name">HMS</field>
        <field name="sequence">10</field>
    </record>

    <!-- Groups -->
    <record id="group_hms_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_hms"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_hms_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_hms"/>
        <field name="implied_ids" eval="[(4, ref('group_hms_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- Record Rules for Patient -->
    <record id="rule_hms_patient_user" model="ir.rule">
        <field name="name">User: Own Patients Only</field>
        <field name="model_id" ref="model_hms_patient"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_hms_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_hms_patient_manager" model="ir.rule">
        <field name="name">Manager: All Patients</field>
        <field name="model_id" ref="model_hms_patient"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_hms_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Record Rules for Patient Log -->
    <record id="rule_hms_patient_log_user" model="ir.rule">
        <field name="name">User: Own Patient Logs Only</field>
        <field name="model_id" ref="model_hms_patient_log"/>
        <field name="domain_force">[('patient_id.create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_hms_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_hms_patient_log_manager" model="ir.rule">
        <field name="name">Manager: All Patient Logs</field>
        <field name="model_id" ref="model_hms_patient_log"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_hms_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
