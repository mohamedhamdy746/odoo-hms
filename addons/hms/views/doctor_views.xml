<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hms_doctors_view_list" model="ir.ui.view">
        <field name="name">hms.doctors.view.list</field>
        <field name="model">hms.doctors</field>
        <field name="arch" type="xml">
            <list>
                <field name="first_name"/>
                <field name="last_name"/>
            </list>
        </field>
    </record>

    <record id="hms_doctors_view_form" model="ir.ui.view">
        <field name="name">hms.doctors.view.form</field>
        <field name="model">hms.doctors</field>
        <field name="arch" type="xml">
            <form string="Doctor">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <group string="Doctor Information">
                            <field name="first_name"/>
                            <field name="last_name"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hms_doctors_action" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hms.doctors</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first doctor
            </p>
        </field>
    </record>
</odoo>
