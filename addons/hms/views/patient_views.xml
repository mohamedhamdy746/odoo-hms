<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hms_patient_view_list" model="ir.ui.view">
        <field name="name">hms.patient.view.list</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <list>
                <field name="first_name"/>
                <field name="last_name"/>
                <field name="birth_date"/>
                <field name="age"/>
                <field name="blood_type"/>
                <field name="pcr"/>
                <field name="department_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="hms_patient_view_form" model="ir.ui.view">
        <field name="name">hms.patient.view.form</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <group string="Personal Information">
                            <field name="first_name"/>
                            <field name="last_name"/>
                            <field name="birth_date"/>
                            <field name="age"/>
                            <field name="address"/>
                        </group>
                        <group string="Medical Information">
                            <field name="blood_type"/>
                            <field name="cr_ratio" required="pcr"/>
                            <field name="pcr"/>
                        </group>
                        <group string="Relations">
                            <field name="department_id" domain="[('is_opened', '=', True)]"/>
                            <field name="department_capacity"/>
                            <field name="doctor_ids" widget="many2many_tags" readonly="not department_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="History" name="history" invisible="age &lt; 50">
                            <field name="history"/>
                        </page>
                        <page string="Log History" name="log_history">
                            <field name="log_ids" readonly="1">
                                <list>
                                    <field name="created_by"/>
                                    <field name="date"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hms_patient_action" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hms.patient</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first patient
            </p>
        </field>
    </record>
</odoo>
