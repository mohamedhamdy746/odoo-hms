<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hms_department_view_list" model="ir.ui.view">
        <field name="name">hms.department.view.list</field>
        <field name="model">hms.department</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="capacity"/>
                <field name="is_opened"/>
            </list>
        </field>
    </record>

    <record id="hms_department_view_form" model="ir.ui.view">
        <field name="name">hms.department.view.form</field>
        <field name="model">hms.department</field>
        <field name="arch" type="xml">
            <form string="Department">
                <sheet>
                    <group>
                        <group string="Department Details">
                            <field name="name"/>
                            <field name="capacity"/>
                            <field name="is_opened"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Patients" name="patients">
                            <field name="patient_ids" readonly="1">
                                <list>
                                    <field name="first_name"/>
                                    <field name="last_name"/>
                                    <field name="age"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hms_department_action" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">hms.department</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first department
            </p>
        </field>
    </record>
</odoo>
